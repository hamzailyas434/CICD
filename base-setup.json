{
  "$schema": "./base-setup.schema.json",
  "version": "1.0",
  "_description": "Organization-wide defaults for all CI/CD pipelines. Any project-setup.json that extends this file inherits these values and overrides only what is project-specific.",

  "organization": {
    "name": "Factory42",
    "domainSuffix": "factory42.io",
    "ownerTeam": "platform-team@factory42.com",
    "timeZone": "Europe/Berlin"
  },

  "repositoryDefaults": {
    "provider": "github",
    "org": "factory42",
    "defaultBranch": "main",
    "branchStrategy": "trunk-based",
    "protectedBranches": ["main"],
    "requireSignedCommits": true,
    "requiredStatusChecks": ["lint", "typecheck", "unit-tests", "docker-build"]
  },

  "runtime": {
    "node": "20-lts",
    "packageManager": "pnpm",
    "typescript": "mandatory",
    "defaultFramework": "nextjs",
    "commands": {
      "dev": "pnpm dev",
      "install": "pnpm install --frozen-lockfile",
      "build": "pnpm build",
      "start": "pnpm start",
      "test": "pnpm test"
    }
  },

  "qualityDefaults": {
    "lint":         { "enabled": true,  "command": "pnpm lint",      "failOnWarning": true },
    "typecheck":    { "enabled": true,  "command": "pnpm typecheck" },
    "unitTests":    { "enabled": true,  "command": "pnpm test",      "coverageThreshold": 80 },
    "e2eTests":     { "enabled": false, "command": "pnpm test:e2e" },
    "securityScan": { "enabled": true,  "tool": "github-codeql",     "failOn": "high" }
  },

  "dockerDefaults": {
    "enabled": true,
    "dockerfile": "./Dockerfile",
    "baseImage": "node:lts-alpine",
    "composeFile": "./docker-compose.yml",
    "registry": {
      "provider": "ghcr",
      "url": "ghcr.io/factory42",
      "authSecret": "GHCR_TOKEN"
    },
    "tagStrategy": "git-sha",
    "additionalTags": ["branch", "stage"]
  },

  "hostingPlatforms": {
    "primary": "vercel",
    "allowed": ["vercel", "railway", "render"],
    "defaultRegion": "fra1"
  },

  "databaseDefaults": {
    "engine": "postgres",
    "provider": "supabase",
    "region": "eu-central-1",
    "migrations": {
      "enabled": true,
      "tool": "supabase-cli",
      "path": "./supabase/migrations",
      "runOn": ["dev", "staging", "prod"]
    },
    "statementTimeoutMs": 5000,
    "rlsRequired": true,
    "prodSafeguards": { "pitr": true, "dailySnapshots": true }
  },

  "stageTemplates": {
    "dev": {
      "trigger":       { "type": "auto", "on": "push", "branch": "main" },
      "approvers":     [],
      "runMigrations": true,
      "seedDatabase":  true,
      "smokeTests":    ["/health"]
    },
    "staging": {
      "trigger":           { "type": "manual", "workflow": "deploy-staging.yml" },
      "approvers":         ["@factory42/tech-leads"],
      "runMigrations":     true,
      "seedDatabase":      false,
      "mirrorsProduction": true,
      "smokeTests":        ["/health", "/api/status"]
    },
    "prod": {
      "trigger":       { "type": "manual", "workflow": "deploy-prod.yml", "requireReleaseTag": true },
      "approvers":     ["@factory42/release-managers"],
      "runMigrations": true,
      "seedDatabase":  false,
      "smokeTests":    ["/health"],
      "rollback":      { "strategy": "previous-image", "autoOnHealthFail": true }
    }
  },

  "secretsDefaults": {
    "provider": "vercel-encrypted",
    "required": [
      "SUPABASE_URL",
      "SUPABASE_ANON_KEY",
      "SUPABASE_SERVICE_ROLE_KEY",
      "NEXTAUTH_SECRET"
    ],
    "forbiddenInClient": ["SUPABASE_SERVICE_ROLE_KEY"],
    "rotationDays": 90,
    "allowPlainTextEnvInProd": false
  },

  "observabilityDefaults": {
    "apm":     { "enabled": true, "provider": "sentry", "dsnSecret": "SENTRY_DSN", "sourceMaps": true },
    "logging": { "format": "json", "provider": "axiom", "retentionDays": 30 },
    "healthEndpoint": "/health",
    "uptime":  { "provider": "checkly", "probeIntervalSeconds": 60 }
  },

  "securityDefaults": {
    "mfaRequiredForAdmins": true,
    "tlsMinVersion": "1.3",
    "encryptionAtRest": "aes-256",
    "auditLog": { "enabled": true, "provider": "supabase-audit" }
  },

  "complianceDefaults": {
    "dataResidency": "eu-central-1",
    "gdpr": {
      "rightToErasure": true,
      "consentLayer":   true,
      "dpaRequired":    true
    }
  },

  "notificationsDefaults": {
    "email":    { "distributionList": "releases@factory42.com" },
    "notifyOn": ["deploy-success", "deploy-failure", "rollback", "migration-applied"]
  }
}
